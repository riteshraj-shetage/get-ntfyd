# Public Host and Email Configuration
PUBLIC_HOST=notify.example.com
EMAIL=admin@example.com

# Timezone (e.g., Asia/Kolkata)
TZ=UTC

# Gateway (planned)
# Shared API key for apps calling the gateway (v1)
# GATEWAY_API_KEY=change-me

# Default tenant ID (used to generate topic prefixes)
# DEFAULT_TENANT_ID=dev

# If ntfy publishing requires auth (optional)
# NTFY_PUBLISH_USER=
# NTFY_PUBLISH_PASS=

# OPTIONAL: SMTP Configuration
# Set these to enable email notifications from ntfy
# Example for Gmail:
# SMTP_SENDER_ADDR=smtp.gmail.com:587
# SMTP_SENDER_FROM=ntfy@example.com
# SMTP_SENDER_USER=your-email@gmail.com
# SMTP_SENDER_PASS=your-app-password


# Web Push (Optional - Advanced)
# Generate keys with: docker exec -it ntfy ntfy webpush keys

# NTFY_WEB_PUSH_PUBLIC_KEY=
# NTFY_WEB_PUSH_PRIVATE_KEY=
# NTFY_WEB_PUSH_FILE=/var/lib/ntfy/webpush.db
# NTFY_WEB_PUSH_EMAIL_ADDRESS=
